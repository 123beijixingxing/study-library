<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.studylib.modules.question.mapper.QuestionOptionMapper">

  <resultMap id="QuestionOptionResultMap" type="com.studylib.modules.question.entity.QuestionOptionEntity">
    <id column="id" property="id" />
    <result column="question_id" property="questionId" />
    <result column="option_key" property="optionKey" />
    <result column="option_label" property="optionLabel" />
    <result column="is_correct" property="correct" />
    <result column="sort_no" property="sortNo" />
  </resultMap>

  <select id="selectByQuestionIds" resultMap="QuestionOptionResultMap">
    select id, question_id, option_key, option_label, is_correct, sort_no
    from question_options
    where question_id in
    <foreach collection="questionIds" item="questionId" open="(" separator="," close=")">
      #{questionId}
    </foreach>
    order by question_id asc, sort_no asc, id asc
  </select>

  <delete id="deleteByQuestionId">
    delete from question_options
    where question_id = #{questionId}
  </delete>

  <insert id="insertBatch">
    insert into question_options (question_id, option_key, option_label, is_correct, sort_no)
    values
    <foreach collection="optionList" item="item" separator=",">
      (#{questionId}, #{item.optionKey}, #{item.optionLabel}, #{item.correct}, #{item.sortNo})
    </foreach>
  </insert>
</mapper>
